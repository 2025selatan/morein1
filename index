<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Portal Aplikasi Terpadu</title>
  <!-- Google Fonts & Font Awesome untuk Ikon -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    /* Reset & Dasar Tampilan */
    * {
      box-sizing: border-box;
    }
    body {
      font-family: 'Poppins', sans-serif;
      background-color: #f4f7f6;
      margin: 0;
      padding: 20px;
      color: #333;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    
    /* Container Utama */
    .container {
      flex: 1;
      max-width: 1200px;
      width: 100%;
      margin: 0 auto;
    }

    /* Header Banner */
    .portal-header {
      text-align: center;
      padding: 35px 20px;
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      color: white;
      border-radius: 12px;
      margin-bottom: 30px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    .portal-header h1 {
      margin: 0;
      font-size: 28px;
      font-weight: 700;
      letter-spacing: 1px;
    }
    .portal-header p {
      margin: 8px 0 0 0;
      font-size: 14px;
      opacity: 0.9;
    }

    /* Grid Layout untuk Menu Aplikasi */
    .apps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }

    /* Style Kartu Aplikasi (App Card) */
    .app-card {
      background: white;
      border-radius: 12px;
      padding: 25px 20px;
      text-align: center;
      text-decoration: none;
      color: #333;
      transition: all 0.3s ease;
      box-shadow: 0 4px 6px rgba(0,0,0,0.05);
      border: 1px solid #eef2f5;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
    }
    
    /* Efek Hover Kursor */
    .app-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.12);
      border-color: #2a5298;
    }

    /* Lingkaran Wadah Ikon */
    .app-icon-wrapper {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 15px;
      font-size: 28px;
    }

    /* Judul & Deskripsi Aplikasi di Dalam Kartu */
    .app-title {
      font-weight: 600;
      font-size: 16px;
      margin-bottom: 8px;
      color: #222;
    }
    .app-desc {
      font-size: 12px;
      color: #777;
      line-height: 1.4;
    }

    /* Variasi Warna Latar Belakang Ikon */
    .bg-blue   { background-color: #e3f2fd; color: #1e88e5; }
    .bg-green  { background-color: #e8f5e9; color: #43a047; }
    .bg-orange { background-color: #fff3e0; color: #fb8c00; }
    .bg-purple { background-color: #f3e5f5; color: #8e24aa; }
    .bg-red    { background-color: #ffebee; color: #e53935; }
    .bg-teal   { background-color: #e0f2f1; color: #00897b; }

    /* Footer Profesional */
    .portal-footer {
      text-align: center;
      padding: 20px;
      font-size: 12px;
      color: #888;
      border-top: 1px solid #e0e0e0;
      margin-top: auto;
    }
  </style>
</head>
<body>

  <div class="container">
    <!-- Bagian Header -->
    <div class="portal-header">
      <h1>PORTAL APLIKASI TERPADU</h1>
      <p>Pusat Layanan dan Manajemen Data Integrasi</p>
    </div>

    <!-- Bagian Grid Menu Utama -->
    <div class="apps-grid">

      <!-- MENU 1: PORTAL ORANG TUA -->
      <a href="https://script.google.com/macros/s/AKfycby1NuiJEujywABiuQ9bvdI-praB8dAV-ZGfvHHf5nXKASYUqqxZNafcSwcyNmOALczu/exec?portal=ortu" target="_blank" class="app-card">
        <div class="app-icon-wrapper bg-blue">
          <i class="fa-solid fa-users"></i>
        </div>
        <div class="app-title">Portal Orang Tua</div>
        <div class="app-desc">Sistem monitoring data perkembangan anak khusus orang tua atau wali.</div>
      </a>

      <!-- MENU 2: DOKTER UMUM -->
      <a href="GANTI_DENGAN_LINK_DOKTER_UMUM" target="_blank" class="app-card">
        <div class="app-icon-wrapper bg-green">
          <i class="fa-solid fa-user-doctor"></i>
        </div>
        <div class="app-title">Poli Dokter Umum</div>
        <div class="app-desc">Input data rekam medis, rujukan, dan manajemen pasien poli umum.</div>
      </a>

      <!-- MENU 3: DOKTER GIGI -->
      <a href="GANTI_DENGAN_LINK_DOKTER_GIGI" target="_blank" class="app-card">
        <div class="app-icon-wrapper bg-orange">
          <i class="fa-solid fa-tooth"></i>
        </div>
        <div class="app-title">Poli Dokter Gigi</div>
        <div class="app-desc">Pencatatan tindakan medis gigi dan antrean pasien poli gigi.</div>
      </a>

      <!-- MENU 4: TRACKING IMUNISASI -->
      <a href="GANTI_DENGAN_LINK_IMUNISASI" target="_blank" class="app-card">
        <div class="app-icon-wrapper bg-purple">
          <i class="fa-solid fa-syringe"></i>
        </div>
        <div class="app-title">Tracking Imunisasi</div>
        <div class="app-desc">Monitoring pelaksanaan vaksinasi harian dan rekap jenis vaksin.</div>
      </a>

      <!-- MENU 5: ARSIP DIAGNOSA (PDF) -->
      <a href="GANTI_DENGAN_LINK_ARSIP_PDF" target="_blank" class="app-card">
        <div class="app-icon-wrapper bg-red">
          <i class="fa-solid fa-file-pdf"></i>
        </div>
        <div class="app-title">Arsip Diagnosa</div>
        <div class="app-desc">Manajemen otomatisasi berkas PDF rekam diagnosa pasien.</div>
      </a>

      <!-- MENU 6: SINKRONISASI DATA -->
      <a href="GANTI_DENGAN_LINK_SYNC" target="_blank" class="app-card">
        <div class="app-icon-wrapper bg-teal">
          <i class="fa-solid fa-rotate"></i>
        </div>
        <div class="app-title">Sinkronisasi Data</div>
        <div class="app-desc">Panel integrasi API data lokal menuju sistem database cloud.</div>
      </a>

    </div>
  </div>

  <!-- Bagian Footer Resmi -->
  <div class="portal-footer">
    <p>&copy; 2026 UPLOAD. All Rights Reserved. <br> Dikembangkan untuk Efisiensi Manajemen Layanan.</p>
  </div>

</body>
</html>
